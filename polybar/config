include-file = ~/.config/polybar/modules.ini
include-file = ~/.config/polybar/colors-dark.ini

[bar/bspwm]
monitor = ${env:MONITOR:}
width = 100%
height = 40
fixed-center = true
border-size= 0
background = ${colors.background}
foreground = ${colors.foreground}
padding-left = 2
padding-right = 2
module-margin-left = 1
module-margin-right = 1
font-0 = RobotoMono Nerd Font Mono:weight=SemiBold:size=10;2
font-1 = RobotoMono Nerd Font Mono:size=12;2
font-2 = Hack Nerd Font:weight=Medium:size=10;2
cursor-click = pointer
cursor-scroll = ns-resize

;;;;;; Module Positioning
modules-left = term hostname music
modules-center = workspaces
modules-right = wallpaper print network audio  battery date powermenu

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false [global/wm] margin-top = 5 margin-bottom = 5 vim:set ft=dosini:
